# ==========================================
# BRUTAL .gitignore FOR UDYAM SAHAYAK
# Covers React+Vite, Python+FastAPI, OS, IDEs
# ==========================================

# ------------------------------------------
# Environments, Secrets & Certificates
# ------------------------------------------
.env
.env.*
!.env.example
*.local
*.secret
*.key
*.pem
*.cert
*.crt
*.p12
*.pfx
*.jks
*.pub
*token*
credentials.json
client_secret.json
auth.json

# ------------------------------------------
# Node.js, Vite & Frontend
# ------------------------------------------
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports
node_report.csv
v8.out
*.cpuprofile
*.heapsnapshot

# Dependencies
node_modules/
jspm_packages/

# Build and Cache
dist/
dist-ssr/
build/
.npm/
.yarn/
.eslintcache
.stylelintcache
.vite/
.tmp/
temp/
coverage/

# ------------------------------------------
# Python, FastAPI & Backend
# ------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Environments
env/
venv/
.env/
.venv/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
/backend/build/
/backend/dist/
/backend/downloads/
/backend/eggs/
/backend/.eggs/
/backend/lib/
/backend/lib64/
/backend/parts/
/backend/sdist/
/backend/var/
/backend/wheels/
/backend/*.egg-info/
/backend/.installed.cfg
/backend/*.egg

# Testing & Coverage
.pytest_cache/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.tox/
htmlcov/
pytestdebug.log

# ------------------------------------------
# Databases & Caches
# ------------------------------------------
*.db
*.sqlite
*.sqlite3
*.duckdb
*.duckdb.wal
*.rdb
*.sql.gz
backend/data/*.db

# ------------------------------------------
# OS Generated Files
# ------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ------------------------------------------
# IDEs & Editors
# ------------------------------------------
# VS Code / Cursor
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.cursor/
*.code-workspace
.history/

# JetBrains / IntelliJ / PyCharm
.idea/
*.iws
*.iml
*.ipr
out/
cmake-build-*/

# Vim / Emacs
*.swp
*.swo
*.swn
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ------------------------------------------
# Archives & Media
# ------------------------------------------
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip
*.log.gz
