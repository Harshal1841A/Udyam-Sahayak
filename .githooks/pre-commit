#!/usr/bin/env python3
"""
Pre-commit hook to prevent committing secrets to git repository.
Enforces SECURITY_final.md zero-secrets requirement.
"""
import subprocess
import sys
import re

PATTERNS = [
    (r"-----BEGIN [A-Z ]+ PRIVATE KEY-----", "Private key pattern detected"),
    (r"(?i)(api[_-]?key|jwt[_-]?secret|secret[_-]?key|password|token)\s*[:=]\s*['\"][A-Za-z0-9\+/\-_]{16,}['\"]", "Potential API key/secret assignment detected"),
    (r"ey[A-Za-z0-9-_=]+\.[A-Za-z0-9-_=]+\.?[A-Za-z0-9-_.+/=]*", "Potential JWT token / Supabase service key detected in code"),
]

def check_staged_files():
    try:
        result = subprocess.run(["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"], capture_output=True, text=True, check=True)
        staged_files = [f.strip() for f in result.stdout.splitlines() if f.strip()]
    except subprocess.CalledProcessError:
        return 0

    errors = []
    for filepath in staged_files:
        if filepath.startswith(".githooks/") or filepath.endswith(".example") or filepath == ".gitignore":
            continue
        try:
            with open(filepath, "r", encoding="utf-8", errors="ignore") as f:
                content = f.read()
                for pattern, desc in PATTERNS:
                    matches = re.findall(pattern, content)
                    if matches:
                        errors.append(f"[{desc}] in file: {filepath}")
                        break
        except Exception as e:
            pass

    if errors:
        print("="*60)
        print("SECURITY ALERT: Commit rejected due to potential secrets detected in staged files:")
        for err in errors:
            print(f"  - {err}")
        print("\nPlease move secrets to environment variables (.env) which are ignored by git.")
        print("="*60)
        return 1

    return 0

if __name__ == "__main__":
    sys.exit(check_staged_files())
